from tkinter import*
from tkinter.colorchooser import askcolor


class Paint(object):
    DEFAULT_COLOR = 'green'
    def __init__(self):
        self.root = Tk()
        self.root.config(bg='yellow')
        self.pen_button = Button(self.root, text='pen',bg='green',
                                fg='yellow', bd = 4, command=self.use_pen)
        self.pen_button.grid(row = 0, column = 0)
        
        self.brush_button = Button(self.root, text='brush', bg = 'green', fg='yellow'
                                , bd=5,command=self.use_brush)
        self.brush_button.grid(row = 0, column = 2)

        self.color_button = Button(self.root, text='color', bg='green', fg='yellow',
                                    bd = 4, command=self.choose_color)
        self.color_button.grid(row=0, column = 3)
        self.eraser_button = Button(self.root, text='eraser', bg='green', fg='yellow',
                                    bd= 4, command=self.use_eraser)
        self.eraser_button.grid(row = 0, column = 4)

        self.choose_size = Scale(self.root, from_ = 1, to = 20, bg='green', fg='yellow'
                            , bd = 4, orient = HORIZONTAL)
        self.choose_size.grid(row = 0, column= 5)

        self.clear_button = Button(self.root, text = 'clear', bg = 'green',
            fg = 'yellow', bd = 4, command = self.clear_canvas)
        self.clear_button.grid(row=0, column=6)

        self.c = Canvas(self.root, bg = 'white', width = 600, height = 700)
        self.c.grid(row= 1 , columnspan=6)


        self.setup()

        self.root.mainloop()

    #Functions
    def setup(self):
        self.old_x = None
        self.old_y = None
        self.line_width = self.choose_size.get()
        self.color = self.DEFAULT_COLOR
        self.eraser_on = False
        self.active_button = self.pen_button
        self.c.bind('<B1-Motion>', self.paint)
        self.c.bind('<ButtonRelease-1>', self.reset)

    def use_pen(self): 
        self.activate_button(self.pen_button)

    def use_brush(self):
        self.activate_button(self.brush_button)

    def choose_color(self):
        self.eraser_on = False
        self.color = askcolor(color = self.color)[1]

    def use_eraser(self):
        self.activate_button(self.eraser_button, eraser_mode= True)

    def activate_button(self, some_button, eraser_mode = False):
        self.active_button.config(relief = RAISED)
        some_button.config(relief = SUNKEN)
        self.active_button = some_button
        self.eraser_on = eraser_mode

    def paint(self, event):
        self.line_width = self.choose_size.get()
        self.paint_color = 'white' if self.eraser_on else self.color
        
        if self.old_x and self.old_y:
            self.c.create_line(self.old_x, self.old_y, event.x, event.y,
                               width = self.line_width,
                               fill = self.paint_color,
                               capstyle = ROUND,
                               smooth= TRUE,
                               splinesteps = 37)
        self.old_x = event.x
        self.old_y = event.y


    def clear_canvas(self):
        self.c.delete('all')

    def reset(self, event):
        self.old_x = None
        self.old_y = None

if __name__ == '__main__':
    Paint()
